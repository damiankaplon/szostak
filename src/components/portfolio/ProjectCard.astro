---
// Kafelek pojedynczej realizacji w siatce portfolio.
// `data-cat` jest odczytywane przez filtr kategorii (ProjectFilters).
import type { Project, ProjectCategory } from "../../data/projects";
import { categoryLabels } from "../../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

// Etykieta dynamiczna (Strapi) lub statyczna mapa (strona główna).
const catLabel =
  project.categoryLabel ?? categoryLabels[project.category as ProjectCategory] ?? project.category;
---

<a href={`/projekty/${project.slug}`} class:list={["proj", `s-${project.size}`]} data-cat={project.category}>
  <div class="proj__media">
    <div class="proj__img" style={`background-image:url('${project.image}')`}></div>
  </div>
  <span class="proj__plus">＋</span>
  <div class="proj__meta">
    <span class="proj__cat">{catLabel}</span>
    <h3>{project.title}</h3>
  </div>
</a>
