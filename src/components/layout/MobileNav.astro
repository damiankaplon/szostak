---
// Pełnoekranowe menu mobilne. Otwierane przyciskiem-burgerem z nagłówka
// (data-mopen), zamykane krzyżykiem, linkiem lub po wyborze pozycji.
import Logo from "../ui/Logo.astro";
import Button from "../ui/Button.astro";
import { navLinks } from "../../data/site";
---

<div class="mnav" aria-hidden="true">
  <div class="mnav__top">
    <Logo as="span" style="color:#fff" />
    <button class="iconbtn" data-mclose aria-label="Zamknij menu">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.8" />
      </svg>
    </button>
  </div>

  <nav class="mnav__links">
    {
      navLinks.map((l, i) => (
        <a href={l.href}>
          <span class="ix">{String(i + 1).padStart(2, "0")}</span>
          {l.label}
        </a>
      ))
    }
  </nav>

  <div style="margin-top:auto; padding-top:30px;">
    <Button href="/kontakt" variant="accent" class="" style="width:100%; justify-content:center;">
      Darmowa wycena
    </Button>
  </div>
</div>

<script>
  // Otwieranie / zamykanie menu mobilnego.
  const mnav = document.querySelector(".mnav");
  const openBtn = document.querySelector("[data-mopen]");
  const closeBtn = document.querySelector("[data-mclose]");

  openBtn?.addEventListener("click", () => mnav?.classList.add("open"));
  closeBtn?.addEventListener("click", () => mnav?.classList.remove("open"));
  document
    .querySelectorAll(".mnav__links a")
    .forEach((a) => a.addEventListener("click", () => mnav?.classList.remove("open")));
</script>
