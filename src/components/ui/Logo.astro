---
// Znak + logotyp SZOSTAK PROJEKT.
// Renderowany w nagłówku, menu mobilnym i stopce. Kolor dziedziczy z
// kontekstu (currentColor); akcentowany prostokąt używa --accent.
//
// Props:
//   as    — element wrapujący: "a" (z linkiem) lub "span" (statyczny).
//   href  — adres docelowy, gdy `as="a"` (domyślnie strona główna).
//   class — dodatkowe klasy (np. ustawienie koloru na ciemnym tle).
interface Props {
  as?: "a" | "span";
  href?: string;
  class?: string;
  style?: string;
}

const { as = "a", href = "/", class: className = "", style } = Astro.props;
const Tag = as;
const attrs =
  as === "a"
    ? { href, "aria-label": "Szostak Projekt — strona główna" }
    : {};
---

<Tag class:list={["logo", className]} style={style} {...attrs}>
  <svg class="logo__mark" viewBox="0 0 40 40" fill="none" aria-hidden="true">
    <rect x="4" y="4" width="32" height="7.5" fill="currentColor" />
    <rect x="4" y="4" width="7.5" height="18" fill="currentColor" />
    <rect x="4" y="16.25" width="32" height="7.5" fill="currentColor" />
    <rect x="28.5" y="18.25" width="7.5" height="17.75" fill="var(--accent)" />
    <rect x="4" y="28.5" width="32" height="7.5" fill="currentColor" />
  </svg>
  <span class="logo__type"><b>SZOSTAK</b><span>PROJEKT</span></span>
</Tag>
